#Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_CALLER_NUMBER=+1XXXXXXXXXX

#Assessment target - do not change
TARGET_NUMBER=+18054398008

#Public URL for webhooks (leave blank; start.bat sets this from ngrok)
PUBLIC_WEBHOOK_URL=

#Deepgram (https://console.deepgram.com)
DEEPGRAM_API_KEY=

#Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

#Server
HOST=0.0.0.0
PORT=8000

#Call defaults
MAX_CALL_DURATION_SECONDS=180
SILENCE_OPENING_SECONDS=2

#Latency and voice tuning
TTS_MODEL=aura-2-thalia-en
TTS_GAIN_DB=5
TTS_PLAYBACK_SPEED=1.0
STT_MODEL=nova-2-phonecall
UTTERANCE_END_MS=1100
ENDPOINTING_MS=330
AGENT_LISTEN_COOLDOWN_MS=230
